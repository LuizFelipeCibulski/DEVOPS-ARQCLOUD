#-------------------------------------------------------------
#                           ENV DE EXEMPLO
#-------------------------------------------------------------
# Porta do serviço 
PORT="8005"
# Fila SQS
AWS_SQS_URL="http://ministack:4566/000000000000/MyStandardQueue"
# Tabela Dynamo
AWS_DYNAMODB_TABLE="ToggleMasterAnalytics"
# Região
AWS_REGION="us-east-1"
# Liga o modo local: faz o app.py usar endpoint_url do ministack/dynamodb-local
# em vez de ir na AWS real
DYNAMODB_LOCAL="true"
# Credenciais dummy para o DynamoDB Local
AWS_DYNAMODB_ACCESS_KEY_ID="mock"
AWS_DYNAMODB_SECRET_ACCESS_KEY="mock"
# Credenciais dummy para o ministack (SQS)
AWS_SQS_ACCESS_KEY_ID="test"
AWS_SQS_SECRET_ACCESS_KEY="test"
