#-------------------------------------------------------------
#                           ENV DE EXEMPLO
#-------------------------------------------------------------
# Porta do servico
PORT="8004"
# URL do seu Redis local
REDIS_URL="redis://redis-db:6379"
# URLs dos outros serviços
FLAG_SERVICE_URL="http://app-flag:8002"
TARGETING_SERVICE_URL="http://app-targeting:8003"
# Chave de API que você criou no passo 2
SERVICE_API_KEY="CHAVEDAAPIAQUI"
# URL da fila SQS local, servida pelo container "ministack"
AWS_SQS_URL="http://ministack:4566/000000000000/MyStandardQueue"
# Endpoint do emulador local do SQS
AWS_ENDPOINT_URL="http://ministack:4566"
# Região 
AWS_REGION="us-east-1"
# Credenciais dummy usadas SOMENTE quando AWS_ENDPOINT_URL está setado
AWS_ACCESS_KEY_ID="test"
AWS_SECRET_ACCESS_KEY="test"
